// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELO DE USUARIOS Y AUTENTICACIÓN
// ==========================================

enum RolUsuario {
  ADMIN_TOTAL
  ADMIN
  USUARIO
  SUPERVISOR
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  BLOQUEADO
}

model User {
  id          String        @id @default(uuid())
  nombre      String
  email       String        @unique
  password    String
  rol         RolUsuario    @default(USUARIO)
  estado      EstadoUsuario @default(ACTIVO)
  lastLogin   DateTime?     @map("last_login")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relaciones
  planificacionesCreadas Planificacion[] @relation("PlanificacionCreador")
  visitantesRegistrados  Visitante[]     @relation("VisitanteRegistrador")
  documentosSubidos      Documento[]     @relation("DocumentoCreador")
  logs                   UserLog[]

  @@map("users")
}

// ==========================================
// LOGS DE ACTIVIDAD DE USUARIOS
// ==========================================

enum AccionLog {
  LOGIN
  LOGOUT
  CREAR_USUARIO
  EDITAR_USUARIO
  ELIMINAR_USUARIO
  CAMBIAR_PASSWORD
}

model UserLog {
  id        String     @id @default(uuid())
  accion    AccionLog
  ip        String?
  userAgent String?    @map("user_agent")
  metadata  String?
  createdAt DateTime   @default(now()) @map("created_at")

  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_logs")
}

// ==========================================
// SEDES
// ==========================================

enum EstadoSede {
  ACTIVO
  INACTIVO
}

model Sede {
  id               String       @id @default(uuid())
  nombre           String
  estado           EstadoSede   @default(ACTIVO)
  tiempoDescanso   String?      @map("tiempo_descanso")
  fechaInicial     DateTime?    @map("fecha_inicial")
  fechaFinal       DateTime?    @map("fecha_final")
  nombreColeccion  String?      @map("nombre_coleccion")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relaciones
  centroCostoId    String?      @map("centro_costo_id")
  centroCosto      CentroCosto? @relation(fields: [centroCostoId], references: [id])
  horarios              HorarioSede[]
  empleados             Empleado[]
  destinos              Destino[]
  visitantes            Visitante[]
  planificacionesCargos PlanificacionCargo[]

  @@map("sedes")
}

model HorarioSede {
  id         String  @id @default(uuid())
  dia        String  // LUNES | MARTES | MIERCOLES | JUEVES | VIERNES | SABADO | DOMINGO
  activo     Boolean @default(false)
  horaInicio String? @map("hora_inicio")
  horaFin    String? @map("hora_fin")

  sedeId     String  @map("sede_id")
  sede       Sede    @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, dia])
  @@map("horarios_sede")
}

// ==========================================
// CONTRATISTAS
// ==========================================

enum EstadoContratista {
  ACTIVO
  INACTIVO
}

model Contratista {
  id              String            @id @default(uuid())
  nombre          String
  nit             String?           @unique
  representante   String?
  telefono        String?
  email           String?
  direccion       String?
  estado          EstadoContratista @default(ACTIVO)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relaciones
  empleados              Empleado[]
  planificaciones        Planificacion[]
  planificacionesCargos  PlanificacionCargo[]

  @@map("contratistas")
}

// ==========================================
// CENTROS DE COSTOS
// ==========================================

model CentroCosto {
  id          String   @id @default(uuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  presupuesto Decimal? @db.Decimal(15, 2)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  sedes       Sede[]
  empleados   Empleado[]

  @@map("centros_costos")
}

// ==========================================
// EMPLEADOS
// ==========================================

enum TipoIdentificacion {
  CC
  CE
  PASAPORTE
  NIT
}

enum EstadoEmpleado {
  ACTIVO
  INACTIVO
  VACACIONES
  INCAPACITADO
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR
}

model Empleado {
  id                String             @id @default(uuid())
  tipoId            TipoIdentificacion @default(CC) @map("tipo_id")
  numeroId          String             @map("numero_id")
  nombres           String
  apellidos         String
  email             String?
  telefono          String?
  fechaNacimiento   DateTime?          @map("fecha_nacimiento")
  genero            Genero?
  direccion         String?
  cargo             String?
  fechaIngreso      DateTime           @default(now()) @map("fecha_ingreso")
  fechaRetiro       DateTime?          @map("fecha_retiro")
  salario           Decimal?           @db.Decimal(12, 2)
  estado            EstadoEmpleado     @default(ACTIVO)
  eps               String?
  fondoPensiones    String?            @map("fondo_pensiones")
  arl               String?
  contactoEmergencia String?           @map("contacto_emergencia")
  telefonoEmergencia String?           @map("telefono_emergencia")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  // Relaciones
  sedeId            String             @map("sede_id")
  sede              Sede               @relation(fields: [sedeId], references: [id])
  
  contratistaId     String?            @map("contratista_id")
  contratista       Contratista?       @relation(fields: [contratistaId], references: [id])
  
  centroCostoId     String?            @map("centro_costo_id")
  centroCosto       CentroCosto?       @relation(fields: [centroCostoId], references: [id])
  
  planificaciones   Planificacion[]
  turnos            Turno[]
  documentos        Documento[]

  @@unique([tipoId, numeroId])
  @@map("empleados")
}

// ==========================================
// ACTIVIDADES
// ==========================================

model Actividad {
  id          String   @id @default(uuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  planificaciones Planificacion[]

  @@map("actividades")
}

// ==========================================
// DESTINOS
// ==========================================

enum EstadoDestino {
  ACTIVO
  INACTIVO
}

model Destino {
  id          String        @id @default(uuid())
  nombre      String
  descripcion String?
  estado      EstadoDestino @default(ACTIVO)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relaciones
  sedeId      String        @map("sede_id")
  sede        Sede          @relation(fields: [sedeId], references: [id])
  
  planificaciones Planificacion[]

  @@map("destinos")
}

// ==========================================
// PLANIFICACIÓN
// ==========================================

enum EstadoPlanificacion {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

model Planificacion {
  id              String              @id @default(uuid())
  fecha           DateTime
  descripcion     String?
  estado          EstadoPlanificacion @default(PENDIENTE)
  horaInicio      DateTime?           @map("hora_inicio")
  horaFin         DateTime?           @map("hora_fin")
  observaciones   String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  // Relaciones
  creadorId       String              @map("creador_id")
  creador         User                @relation("PlanificacionCreador", fields: [creadorId], references: [id])
  
  empleadoId      String              @map("empleado_id")
  empleado        Empleado            @relation(fields: [empleadoId], references: [id])
  
  contratistaId   String?             @map("contratista_id")
  contratista     Contratista?        @relation(fields: [contratistaId], references: [id])
  
  actividadId     String?             @map("actividad_id")
  actividad       Actividad?          @relation(fields: [actividadId], references: [id])
  
  destinoId       String?             @map("destino_id")
  destino         Destino?            @relation(fields: [destinoId], references: [id])

  @@map("planificaciones")
}

model PlanificacionCargo {
  id            String      @id @default(uuid())
  cargo         String
  cantidad      Int
  fechaInicio   DateTime    @map("fecha_inicio")
  fechaFin      DateTime    @map("fecha_fin")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  contratistaId String      @map("contratista_id")
  contratista   Contratista @relation(fields: [contratistaId], references: [id])

  sedeId        String      @map("sede_id")
  sede          Sede        @relation(fields: [sedeId], references: [id])

  @@map("planificaciones_cargos")
}

// ==========================================
// TURNOS
// ==========================================

enum TipoTurno {
  DIURNO
  NOCTURNO
  MIXTO
  FIN_DE_SEMANA
  FESTIVO
}

enum EstadoTurno {
  PROGRAMADO
  EN_CURSO
  COMPLETADO
  CANCELADO
}

model Turno {
  id          String      @id @default(uuid())
  fecha       DateTime
  tipo        TipoTurno   @default(DIURNO)
  horaInicio  DateTime    @map("hora_inicio")
  horaFin     DateTime    @map("hora_fin")
  estado      EstadoTurno @default(PROGRAMADO)
  observaciones String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relaciones
  empleadoId  String      @map("empleado_id")
  empleado    Empleado    @relation(fields: [empleadoId], references: [id])

  @@map("turnos")
}

// ==========================================
// VISITANTES
// ==========================================

enum TipoVisitante {
  PERSONAL
  EMPRESARIAL
  PROVEEDOR
  CLIENTE
  OTRO
}

enum EstadoVisitante {
  EN_SITIO
  FINALIZADA
}

model Visitante {
  id              String          @id @default(uuid())
  tipo            TipoVisitante   @default(PERSONAL)
  nombre          String
  identificacion  String?
  empresa         String?
  telefono        String?
  email           String?
  motivo          String
  fechaEntrada    DateTime        @default(now()) @map("fecha_entrada")
  fechaSalida     DateTime?       @map("fecha_salida")
  estado          EstadoVisitante @default(EN_SITIO)
  observaciones   String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  sedeId          String          @map("sede_id")
  sede            Sede            @relation(fields: [sedeId], references: [id])
  
  registradoPorId String          @map("registrado_por_id")
  registradoPor   User            @relation("VisitanteRegistrador", fields: [registradoPorId], references: [id])

  @@map("visitantes")
}

// ==========================================
// SGSST — CONTRATISTAS Y TRABAJADORES
// ==========================================

model ContratistaSST {
  id                       String   @id @default(uuid())
  // 1. Datos Básicos
  razonSocial              String
  representante            String?
  nombreComercial          String?
  nit                      String   @unique
  nitDigito                String?
  direccion                String?
  telefono                 String?
  email                    String?
  sitioWeb                 String?
  // 2. Clasificación Empresarial
  tipo                     String?
  tamano                   String?
  departamento             String?
  municipio                String?
  actividadEconomica       String?
  // 3. Clasificación SG-SST
  arl                      String?
  nivelRiesgo              String?
  vencimientoSS            String?
  operadorPagoSS           String?
  centroEntrenamiento      String?
  consultaExamenMedico     Boolean  @default(false) @map("consulta_examen_medico")
  ipsExamenes              String?  @map("ips_examenes")
  // 4. Detalles de Contratación
  clasificacionCategoria   String?  @map("clasificacion_categoria")
  clasificacionCuadrante   String?  @map("clasificacion_cuadrante")
  personaContacto          String?  @map("persona_contacto")
  contactoAdmin            String?  @map("contacto_admin")
  actividades              String?
  costoHora                String?  @map("costo_hora")
  // 5. Permisos / Configuración
  activo                   Boolean  @default(true)
  actualizacionMasivaSS    String?  @map("actualizacion_masiva_ss")
  actualizacionMasivaCursos String? @map("actualizacion_masiva_cursos")
  usuario                  String?
  clave                    String?
  permisosEspeciales       Boolean  @default(false) @map("permisos_especiales")
  // 6. Categorización Interna
  categoria1               String?
  categoria2               String?
  categoria3               String?
  // 7. Integración Externa
  codigoSistemaExterno     String?  @map("codigo_sistema_externo")
  // Estado
  estado                   String   @default("Activo")
  diasCorte                Int      @default(0) @map("dias_corte")

  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  trabajadores             TrabajadorSST[]
  soportes                 SoporteContratistaSST[]

  @@map("contratistas_sst")
}

model TrabajadorSST {
  id                   String   @id @default(uuid())
  documento            String
  nombre               String
  cargo                String?
  sede                 String?
  // Flags
  historia             Boolean  @default(false)
  activo               Boolean  @default(true)
  habilitado           Boolean  @default(true)
  parafiscales         Boolean  @default(false)
  certificacion        Boolean  @default(false)
  otrosCursos          Boolean  @default(false) @map("otros_cursos")
  induccion            Boolean  @default(false)
  empleadoActivo       Boolean  @default(true) @map("empleado_activo")
  // Sec 1 — Personal
  fechaExpedicion      String?  @map("fecha_expedicion")
  fechaNacimiento      String?  @map("fecha_nacimiento")
  sexo                 String?
  estadoCivil          String?  @map("estado_civil")
  ubicacionFisica      String?  @map("ubicacion_fisica")
  tipoVinculacion      String?  @map("tipo_vinculacion")
  salario              String?
  nivelEscolaridad     String?  @map("nivel_escolaridad")
  raza                 String?
  // Sec 2 — Contacto / Vital
  correo               String?
  eps                  String?
  direccionResidencia  String?  @map("direccion_residencia")
  telefonoResidencia   String?  @map("telefono_residencia")
  telefonoMovil        String?  @map("telefono_movil")
  grupoSanguineo       String?  @map("grupo_sanguineo")
  discapacidad         String?
  contactoEmergencias  String?  @map("contacto_emergencias")
  telefonoEmergencias  String?  @map("telefono_emergencias")
  enfermedades         String[] @default([])
  transporte           String?
  ingresoEmpresa       String?  @map("ingreso_empresa")
  retiroEmpresa        String?  @map("retiro_empresa")
  // Sec 3 — Certificaciones
  vencExamen           String?  @map("venc_examen")
  vencAlturas          String?  @map("venc_alturas")
  vencConfinados       String?  @map("venc_confinados")
  certRequeridas       String[] @default([]) @map("cert_requeridas")
  // Sec 4 — Controles de Acceso
  accesoContratista    Boolean  @default(true) @map("acceso_contratista")
  estadoSS             Boolean  @default(false) @map("estado_ss")
  certTareas           Boolean  @default(false) @map("cert_tareas")
  cursoEspecifico      Boolean  @default(false) @map("curso_especifico")
  induccionSitio       Boolean  @default(false) @map("induccion_sitio")
  fechaRevision        String?  @map("fecha_revision")
  periodicidadExamen   Int      @default(365) @map("periodicidad_examen")
  accesoGeneral        Boolean  @default(true) @map("acceso_general")
  // Sec 5 — Multimedia / Notas
  fotografia           String?
  notas                String?

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  contratistaId        String                  @map("contratista_id")
  contratista          ContratistaSST          @relation(fields: [contratistaId], references: [id], onDelete: Cascade)
  soportes             SoporteContratistaSST[]

  @@map("trabajadores_sst")
}

// ==========================================
// SGSST — SOPORTES DE CONTRATISTAS
// ==========================================

model SoporteContratistaSST {
  id              String          @id @default(uuid())
  nombre          String
  tipoDocumento   String?         @map("tipo_documento")
  descripcion     String?
  storageKey      String          @map("storage_key")
  mimeType        String          @map("mime_type")
  tamanio         Int
  creadoEn        DateTime        @default(now()) @map("creado_en")

  contratistaId   String?         @map("contratista_id")
  contratista     ContratistaSST? @relation(fields: [contratistaId], references: [id], onDelete: Cascade)

  trabajadorId    String?         @map("trabajador_id")
  trabajador      TrabajadorSST?  @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@map("soportes_contratistas_sst")
}

// ==========================================
// DOCUMENTOS
// ==========================================

enum TipoDocumento {
  CONTRATO
  CEDULA
  HV
  CERTIFICADO
  LICENCIA
  EXAMEN_MEDICO
  POLIZA
  OTRO
}

model Documento {
  id          String        @id @default(uuid())
  nombre      String
  tipo        TipoDocumento
  descripcion String?
  url         String
  tamanio     Int           @map("tamanio")
  mimeType    String        @map("mime_type")
  carpeta     String        @default("general")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relaciones
  empleadoId  String?       @map("empleado_id")
  empleado    Empleado?     @relation(fields: [empleadoId], references: [id])
  
  subidoPorId String        @map("subido_por_id")
  subidoPor   User          @relation("DocumentoCreador", fields: [subidoPorId], references: [id])

  @@map("documentos")
}
